# Copy to .env and fill in your values. Never commit .env to git.

# MongoDB Atlas (works on all networks via port 443)
MONGO_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# true = mock predictor (demo), false = real sklearn LR (run deploy_best_model.py first)
USE_MOCK_MODEL=true

# JWT — generate: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
TWO_FA_ISSUER=PhishGuard

# Gemini AI — free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_RATE_LIMIT_SECONDS=60

# Storage paths
DATASET_STORAGE_PATH=./datasets
MODEL_STORAGE_PATH=./trained_models
FRONTEND_URL=http://localhost:5173
